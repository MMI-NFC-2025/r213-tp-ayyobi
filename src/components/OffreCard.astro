---
import PbImage from "../components/PbImage.astro";
const { offre } = Astro.props;
---

<article
  class="rounded-lg overflow-hidden bg-white shadow-md hover:shadow-lg transition"
>
  <div class="h-48 overflow-hidden bg-slate-100 relative">
    <PbImage record={offre} recordImage={offre.images} />
  </div>
  <div class="p-4">
    <h2 class="text-lg font-bold mb-2 text-gray-900 line-clamp-2">
      {offre.nom_maison}
    </h2>
    <div class="space-y-1 mb-4 text-sm text-gray-700">
      <p>
        <strong>Prix:</strong>
        {offre.prix?.toLocaleString("fr-FR") || offre.prix} €
      </p>
      <p><strong>Surface:</strong> {offre.surface} m²</p>
      <p><strong>Adresse:</strong> {offre.adresse}</p>
    </div>
    <div class="flex gap-2">
      <a
        href={`/offres/${offre.id}`}
        class="flex-1 text-center px-4 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition"
      >
        Voir plus
      </a>
      <button
        class={`favoriteButton px-3 py-2 rounded-lg font-semibold text-sm border transition cursor-pointer ${
          offre.favori
            ? "bg-yellow-100 text-yellow-800 border-yellow-300"
            : "bg-gray-100 text-gray-700 border-gray-300"
        }`}
        data-favorite-label
        data-offre={JSON.stringify(offre)}
        type="button"
      >
        {offre.favori ? "⭐ Favori" : "☆ Ajouter"}
      </button>
    </div>
  </div>
</article>

<script>
  //@ts-nocheck
  const favoriteButtons = document.querySelectorAll(".favoriteButton");

  favoriteButtons.forEach((button) => {
    button.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();

      const offreData = JSON.parse(button.dataset.offre || "{}");
      const newFavori = !offreData.favori;

      const response = await fetch("/api/setFavori", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ...offreData,
          favori: newFavori,
        }),
      });

      if (!response.ok) {
        console.error("Erreur API favori", await response.text());
        return;
      }

      const article = button.closest("article");
      const favIcon = article?.querySelector("#favorite-icon");
      if (favIcon instanceof HTMLImageElement) {
        favIcon.src = newFavori ? "/favorite_filled.svg" : "/favorite.svg";
      }

      if (button instanceof HTMLButtonElement) {
        button.textContent = newFavori ? "⭐ Favori" : "☆ Ajouter";
        button.className = `favoriteButton px-3 py-2 rounded-lg font-semibold text-sm border transition cursor-pointer ${
          newFavori
            ? "bg-yellow-100 text-yellow-800 border-yellow-300"
            : "bg-gray-100 text-gray-700 border-gray-300"
        }`;
      }

      offreData.favori = newFavori;
      button.dataset.offre = JSON.stringify(offreData);
    });
  });
</script>

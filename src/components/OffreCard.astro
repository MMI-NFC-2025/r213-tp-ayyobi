---
import PbImage from "./PbImage.astro";
const { offre } = Astro.props;
---

<article class="rounded-lg p-4 shadow-sm rounded-full">
  <PbImage record={offre} recordImage={offre.images} />
  <h2 class="text-lg font-semibold">{offre.nomMaison}</h2>
  <p class="text-slate-600">{offre.adresse}</p>

  <div class="mt-2 flex gap-3 text-sm">
    <span>{offre.nbChambres} ch</span>
    <span>{offre.nbSdb} sdb</span>
    <span>{offre.surface} m²</span>
  </div>

  <p class="mt-2 font-bold">{offre.prix} € / mois</p>

  <button
    class="mt-2 px-2 py-1 text-xs rounded-md border
         transition
         {offre.favori
           ? 'bg-yellow-200 border-yellow-400 text-yellow-900'
           : 'bg-gray-100 border-gray-300 text-gray-600'}"
  >
    {offre.favori ? "⭐ Favori" : "☆ Non favori"}
  </button>
</article>

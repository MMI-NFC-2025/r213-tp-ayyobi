---
import { getOffresBetweenPrix } from "../../../../backend.mjs";
import Layout from "../../../../layouts/Layout.astro";
import OffreCard from "../../../../components/OffreCard.astro";

const { min, max } = Astro.params;
const minPrix = Number(min);
const maxPrix = Number(max);

const offres =
  Number.isFinite(minPrix) && Number.isFinite(maxPrix)
    ? await getOffresBetweenPrix(minPrix, maxPrix)
    : [];
---

<Layout titre={`Maisons entre ${minPrix}€ et ${maxPrix}€`}>
  <section class="max-w-6xl mx-auto px-4 py-8">
    <h2 class="text-2xl font-bold">Maisons entre {minPrix} € et {maxPrix} €</h2>

    {
      offres.length === 0 ? (
        <p class="mt-4">Aucune offre trouvée.</p>
      ) : (
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 items-stretch">
          {offres.map((offre) => (
            <OffreCard offre={offre} />
          ))}
        </div>
      )
    }
  </section>
</Layout>

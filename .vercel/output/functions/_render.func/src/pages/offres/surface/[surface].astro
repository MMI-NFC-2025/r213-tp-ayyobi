---
import { getOffresMinSurface } from "../../../backend.mjs";
import Layout from "../../../layouts/Layout.astro";
import OffreCard from "../../../components/OffreCard.astro";

const { surface } = Astro.params;
const minSurface = Number(surface);

const offres = Number.isFinite(minSurface)
  ? await getOffresMinSurface(minSurface)
  : [];
---

<Layout titre={`Maisons > ${minSurface} m²`}>
  <h2 class="text-2xl font-bold">
    Maisons dont la surface est supérieure à {minSurface} m²
  </h2>

  {
    offres.length === 0 ? (
      <p class="mt-4">Aucune offre trouvée.</p>
    ) : (
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {offres.map((offre) => (
          <OffreCard offre={offre} />
        ))}
      </div>
    )
  }
</Layout>
